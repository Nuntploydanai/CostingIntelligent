{
  "name": "costing-intelligent-v2",
  "version": "2.0.0",
  "description": "Basic Shirts Costing Tool - Node.js Version",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.ts",
    "client:dev": "cd client && npm run dev",
    "build": "tsc && cd client && npm run build",
    "start": "node dist/server/index.js"
  },
  "keywords": ["costing", "apparel", "manufacturing"],
  "author": "Nunt",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
